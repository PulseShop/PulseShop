# Copy to .env.local and fill in your Supabase project values.
# Both are browser-safe (the publishable/anon key is guarded by row-level security).
# Find them in Supabase: Project Settings -> API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Base URL of the backend payments API (M-Pesa/PayPal). Leave unset to simulate
# payments during development. e.g. https://api.pulseshop.space/payments
VITE_PAYMENTS_API=
