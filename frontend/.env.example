# Copy to .env.local and fill in your Supabase project values.
# Both are browser-safe (the publishable/anon key is guarded by row-level security).
# Find them in Supabase: Project Settings -> API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Base URL of the backend payments API (M-Pesa/PayPal). Leave unset to simulate
# payments during development. e.g. https://api.pulseshop.space/payments
VITE_PAYMENTS_API=

# Cloudflare Turnstile SITE key (public — the SECRET key goes in the Supabase
# dashboard under Auth -> Attack Protection -> CAPTCHA, never here).
#
# Leave unset and the captcha is disabled entirely: the widget renders nothing
# and the auth forms behave exactly as before, so local dev needs no setup.
#
# This is the control that actually limits who can hammer the auth endpoints.
# You cannot restrict the Supabase API to your own domain — CORS is enforced by
# the browser, so a script can just curl the endpoint with no Origin header at
# all, and the anon key above is public by design (it ships in the JS bundle).
# RLS is the access boundary; the captcha is what stops bulk signups and
# password-reset email floods.
VITE_TURNSTILE_SITE_KEY=
